FLASK_DEBUG=1
SECRET_KEY=cambia-esta-clave-en-produccion
DATABASE_URL=sqlite:///animallibre.db

# Credenciales del panel admin
ADMIN_USERNAME=admin
# Genera el hash con: python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('tu-clave'))"
ADMIN_PASSWORD_HASH=

# Correo del administrador (donde llegan las notificaciones)
ADMIN_EMAIL=admin@animallibre.com

# Configuración SMTP para enviar correos
# Para Gmail: activa "Contraseñas de aplicación" en tu cuenta Google
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=tucorreo@gmail.com
MAIL_PASSWORD=tu-contrasena-de-aplicacion
MAIL_DEFAULT_SENDER=Animal Libre <tucorreo@gmail.com>
